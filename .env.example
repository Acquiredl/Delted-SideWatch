# P2Pool
P2POOL_API_URL=http://p2pool:3333
P2POOL_SIDECHAIN=mini

# Monerod
MONEROD_URL=http://monerod:18081
MONEROD_ZMQ_URL=tcp://monerod:18083

# Postgres
POSTGRES_HOST=postgres
POSTGRES_DB=p2pool_dashboard
POSTGRES_USER=manager_user
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis:6379

# Manager
API_PORT=8081
METRICS_PORT=9090
# IMPORTANT: Change this from default! Used for /admin endpoints.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=changeme-generate-a-real-token

# Gateway
GATEWAY_PORT=8080
JWT_SECRET=changeme-in-production
RATE_LIMIT_RPS=10

# Logging
LOG_LEVEL=info

# Frontend WebSocket URL (browser-side, points to gateway or nginx)
# In dev: ws://localhost:8080  In prod (via nginx): omit (uses same-origin)
# NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Price Oracle (optional, defaults to CoinGecko public API)
# COINGECKO_URL=https://api.coingecko.com/api/v3/simple/price?ids=monero&vs_currencies=usd,cad

# Subscription (optional — omit WALLET_RPC_URL to disable payment scanning)
# WALLET_RPC_URL=http://wallet-rpc:18088
# SUBSCRIPTION_MIN_USD=4.0        # Minimum USD equivalent to accept ($5 target, 20% tolerance)
# SUBSCRIPTION_DURATION_DAYS=30   # Subscription length in days
# SUBSCRIPTION_GRACE_HOURS=48     # Grace period after expiry

# GHCR (production — used by deploy.sh when docker-compose.prod.yml is present)
# GHCR_REPO=ghcr.io/acquiredl/delted-sidewatch
# IMAGE_TAG=latest
# GHCR_TOKEN=ghp_...  (or use /run/secrets/ghcr_token)
# GHCR_USER=acquiredl

# Real node (when using docker-compose.node.yml)
# MONERO_WALLET_ADDRESS=4...  (your Monero wallet for P2Pool payouts)
