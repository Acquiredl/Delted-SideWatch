# P2Pool
P2POOL_API_URL=http://p2pool:3333
P2POOL_SIDECHAIN=mini

# Monerod
MONEROD_URL=http://monerod:18081
MONEROD_ZMQ_URL=tcp://monerod:18083

# Postgres
POSTGRES_HOST=postgres
POSTGRES_DB=p2pool_dashboard
POSTGRES_USER=manager_user
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis:6379

# Manager
API_PORT=8081
METRICS_PORT=9090

# Gateway
GATEWAY_PORT=8080
JWT_SECRET=changeme-in-production
RATE_LIMIT_RPS=10

# Logging
LOG_LEVEL=info

# Price Oracle (optional, defaults to CoinGecko public API)
# COINGECKO_URL=https://api.coingecko.com/api/v3/simple/price?ids=monero&vs_currencies=usd,cad
